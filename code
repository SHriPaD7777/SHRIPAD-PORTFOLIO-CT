<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Shripad Pathak | Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #fbfbfb;
        --surface: #ffffff;
        --surface-strong: #f1f5fb;
        --text: #121212;
        --muted: #555b6e;
        --accent: #2f66ff;
        --accent-soft: rgba(47, 102, 255, 0.12);
        --border: #e3e8f1;
        --shadow: 0 24px 60px rgba(19, 25, 45, 0.08);
        --radius: 24px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Poppins", sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .page {
        min-height: 100vh;
        display: grid;
        gap: 4rem;
      }

      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(251, 251, 251, 0.96);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      }

      .nav-container {
        max-width: 1180px;
        margin: 0 auto;
        padding: 1rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        font-weight: 700;
        letter-spacing: -0.04em;
      }

      nav {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }

      .nav-link {
        color: var(--muted);
        transition: color 0.25s ease;
      }

      .nav-link:hover {
        color: var(--text);
      }

      .hero {
        max-width: 1180px;
        margin: 0 auto;
        padding: 4rem 1.5rem 2rem;
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        align-items: center;
        gap: 3rem;
      }

      .hero-copy {
        display: grid;
        gap: 1.5rem;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        font-size: 0.75rem;
        color: var(--accent);
      }

      .hero-title {
        font-size: clamp(2.5rem, 4vw, 4.5rem);
        line-height: 1.02;
        margin: 0;
      }

      .hero-subtitle {
        font-size: 1.2rem;
        color: var(--muted);
        max-width: 44rem;
        line-height: 1.75;
      }

      .button-primary {
        display: inline-block;
        border: none;
        border-radius: 999px;
        padding: 0.95rem 1.8rem;
        font-weight: 600;
        cursor: pointer;
        background: var(--accent);
        color: #fff;
        box-shadow: 0 18px 40px rgba(47, 102, 255, 0.18);
        transition: transform 0.25s ease;
      }

      .button-primary:hover {
        transform: translateY(-2px);
      }

      .hero-visual {
        position: relative;
        min-height: 320px;
        border-radius: var(--radius);
        background: linear-gradient(180deg, rgba(47, 102, 255, 0.14), transparent 68%), #ffffff;
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        display: grid;
        place-items: center;
        padding: 2rem;
      }

      .hero-card {
        width: 100%;
        max-width: 320px;
        background: var(--surface);
        padding: 2rem;
        border-radius: 24px;
        box-shadow: 0 22px 50px rgba(19, 25, 45, 0.08);
      }

      section {
        max-width: 1180px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .section-header {
        margin-bottom: 2rem;
      }

      .section-title {
        margin: 0;
        font-size: 1.75rem;
      }

      .section-subtitle {
        color: var(--muted);
      }

      .about {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 2.5rem;
        align-items: center;
      }

      .about-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
        box-shadow: var(--shadow);
      }

      .skill-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.25rem;
      }

      .skill-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1.5rem;
        transition: transform 0.25s ease;
      }

      .skill-card:hover {
        transform: translateY(-3px);
        border-color: rgba(47, 102, 255, 0.3);
      }

      .projects-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .project-card {
        background: var(--surface);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        box-shadow: var(--shadow);
        padding: 2rem;
        transition: transform 0.25s ease;
      }

      .project-card:hover {
        transform: translateY(-4px);
      }

      .project-link {
        display: inline-flex;
        padding: 0.95rem 1.3rem;
        background: var(--accent);
        color: #fff;
        border-radius: 999px;
        margin-top: 1.5rem;
      }

      .contact-details {
        list-style: none;
        padding: 0;
        margin-top: 1.5rem;
        display: grid;
        gap: 1.25rem;
      }

      .contact-item span {
        font-weight: 600;
        display: block;
      }

      footer {
        padding: 4rem 1.5rem 2rem;
        text-align: center;
        color: var(--muted);
      }

      @media (max-width: 940px) {
        .hero, .about, .projects-grid, .skill-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header>
        <div class="nav-container">
          <a class="brand" href="#home">Shripad Pathak</a>
          <nav>
            <a class="nav-link" href="#home">Home</a>
