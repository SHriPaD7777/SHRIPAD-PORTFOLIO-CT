              <a class="project-link" href="https://www.airdraw.ink/" target="_blank">View Prototype</a>
            </div>
          </div>
        </section>

        <section id="contact">
          <div class="section-header">
            <h2 class="section-title">Contact</h2>
            <p class="section-subtitle">Let's connect.</p>
          </div>
          <div class="contact-card" style="max-width: 500px; margin: 0 auto; border: 1px solid var(--border); border-radius: var(--radius); padding: 2.5rem; background: #fff; box-shadow: var(--shadow);">
            <h3 style="margin-top:0">Get in Touch</h3>
            <ul class="contact-details">
              <li class="contact-item"><span>Email</span><p>shripadrpathak@gmail.com</p></li>
              <li class="contact-item"><span>Phone</span><p>+91 7448240783</p></li>
              <li class="contact-item"><span>PRN</span><p>202501100150</p></li>
            </ul>
          </div>
        </section>
      </main>

      <footer>
        &copy; <span id="year"></span> Shripad Pathak. All rights reserved.
      </footer>
    </div>

    <script>
      document.getElementById('year').textContent = new Date().getFullYear();
    </script>
  </body>
</html>